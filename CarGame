def reset_race():
    player = CarState(pos=START_POS.copy(), vel=pygame.Vector2(0, 0), ang=START_DIR)
    ai = CarState(pos=(START_POS + pygame.Vector2(0, 26)), vel=pygame.Vector2(0, 0), ang=START_DIR)
    return player, ai, "COUNTDOWN", 0.0, None

def checkpoint_mask_for_progress(s):
    mask = 0
    for i, cp in enumerate(CP_S):
        if s >= cp:
            mask |= (1 << i)
    return mask

def draw_track():
