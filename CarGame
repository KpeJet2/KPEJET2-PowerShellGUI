    for cp_s in CP_S:
        p, _, _ = point_at_progress_cached(cp_s)
        pygame.draw.circle(screen, (120, 120, 140), p, CP_RADIUS, 2)

def draw_car(pos, ang, color):
    # Simple triangle
    f = v_from_angle(ang)
    r = v_from_angle(ang - 90)
    p1 = pos + f * 14
    p2 = pos - f * 10 + r * 8
    p3 = pos - f * 10 - r * 8
    pygame.draw.polygon(screen, color, [p1, p2, p3])

def draw_hud(player, ai, state, countdown, result):
    # Boost bar
    pygame.draw.rect(screen, WHITE, (16, 16, 140, 12), 1)
    pygame.draw.rect(screen, BLUE, (16, 16, int(140 * (player.boost / 100.0)), 12))

    # Chain
    chain_txt = FONT.render(f"Chain x{player.chain:.1f}", True, WHITE)
    screen.blit(chain_txt, (16, 36))

    # Time
    t_txt = FONT.render(f"Time: {player.time:.2f}s", True, WHITE)
    screen.blit(t_txt, (16, 56))

    # CP
    cp_txt = FONT.render(f"CP: {bin(player.cp_mask).count('1')}/3", True, WHITE)
    screen.blit(cp_txt, (16, 76))

    # Rival gap (approx by progress)
    _, psi, pt = nearest_on_polyline_cached(player.pos)
    _, asi, at = nearest_on_polyline_cached(ai.pos)
    ps = polyline_progress_cached(psi, pt)
    a_s = polyline_progress_cached(asi, at)
    gap = (ps - a_s)
    # normalize to shortest loop gap
    if gap > TOTAL_S / 2:
        gap -= TOTAL_S
    if gap < -TOTAL_S / 2:
        gap += TOTAL_S
    gap_txt = FONT.render(f"Gap vs Ghostline: {gap:+.0f}m", True, WHITE)
    screen.blit(gap_txt, (16, 96))

    if state == "COUNTDOWN":
        msg = "3" if countdown < 1 else "2" if countdown < 2 else "1" if countdown < 3 else "GO!"
        txt = BIG.render(msg, True, WHITE)
        screen.blit(txt, (W // 2 - txt.get_width() // 2, 40))
    elif state == "RESULT":
        title = BIG.render("RESULTS", True, WHITE)
        screen.blit(title, (W // 2 - title.get_width() // 2, 28))

        lines = [
            f"Your time: {result['player_time']:.2f}s",
            f"Ghostline: {result['ai_time']:.2f}s",
            f"Outcome: {result['outcome']}",
            f"Drift efficiency: {result['drift_eff']:.0f}%",
            "Press ENTER to retry, ESC to quit",
        ]
        y = 92
        for line in lines:
            t = FONT.render(line, True, WHITE)
            screen.blit(t, (W // 2 - t.get_width() // 2, y))
            y += 26

def run_self_test():
    class KeyState:
        def __getitem__(self, key):
            return False

    # Geometry and progress checks
    assert abs(clamp(5, 0, 4) - 4) < 1e-9
    assert abs(clamp(-1, 0, 4) - 0) < 1e-9
    assert TOTAL_S > 0

    p0, si0, t0 = point_at_progress_cached(0)
    assert (p0 - center[0]).length() < 1e-6
    s0 = polyline_progress_cached(si0, t0)
    assert abs(s0 - 0.0) < 1e-6

    d, si, t = nearest_on_polyline_cached(center[3])
    assert d < 1e-6
    s = polyline_progress_cached(si, t)
    p_back, _, _ = point_at_progress_cached(s)
    assert (p_back - center[3]).length() < 1e-6

    # Update loops should execute without exceptions
    player = CarState(pos=START_POS.copy(), vel=pygame.Vector2(0, 0), ang=START_DIR)
    ai = CarState(pos=(START_POS + pygame.Vector2(0, 26)), vel=pygame.Vector2(0, 0), ang=START_DIR)
    keys = KeyState()
    tune_p = CarTuning()
    tune_ai = CarTuning(max_speed=7.6, accel=0.26, brake=0.36, turn_deg=3.0, drift_factor=0.905, boost_force=0.50)
    for _ in range(20):
        update_player(player, tune_p, 1.0 / 60.0, keys)
        update_ai(ai, tune_ai, 1.0 / 60.0, 120.0)
        _ = on_track(player.pos)
        _ = on_track(ai.pos)

    return True


def init_game_runtime():
    global FONT, BIG, screen, clock
    if not HAS_PYGAME:
        raise RuntimeError("pygame is required for gameplay")
    pygame.init()
    FONT = pygame.font.SysFont(None, 22)
    BIG = pygame.font.SysFont(None, 44)
    screen = pygame.display.set_mode((W, H))
    pygame.display.set_caption("Slipstream City - Neon Loop (Vertical Slice)")
    clock = pygame.time.Clock()


def run_game_loop():
    player, ai, state, countdown, result = reset_race()
    tune_p = CarTuning()
    tune_ai = CarTuning(max_speed=7.6, accel=0.26, brake=0.36, turn_deg=3.0, drift_factor=0.905, boost_force=0.50)

    # For drift efficiency metric
    drift_time = 0.0
    drive_time = 0.0

    # AI target progress
    ai_target_s = 0.0

    running = True
    while running:
        dt = clock.tick(FPS) / 1000.0

        for e in pygame.event.get():
            if e.type == pygame.QUIT:
                running = False

        keys = pygame.key.get_pressed()
        if keys[pygame.K_ESCAPE]:
            running = False

        if state == "COUNTDOWN":
            countdown += dt
            if countdown >= 3.2:
                state = "RACE"
                countdown = 0.0

        elif state == "RACE":
            player.time += dt
            ai.time += dt

            # Update player
            update_player(player, tune_p, dt, keys)

            # AI target follows its own progress along centerline
            # (keeps it moving even if it drifts off slightly)
            ai_target_s += (ai.vel.length() * 10.0) * dt
            update_ai(ai, tune_ai, dt, ai_target_s, aggression=0.55)

            # Track collision
            if not on_track(player.pos):
                # crash penalty: bounce + chain break + boost loss
                player.vel *= -0.45
                player.pos += player.vel
                player.chain = 1.0
                player.boost = max(0.0, player.boost - 18.0)
            if not on_track(ai.pos):
                ai.vel *= -0.40
                ai.pos += ai.vel
                ai.boost = max(0.0, ai.boost - 10.0)

            # Shortcut: if player crosses the gate line closely, grant a small progress advantage (but risky)
            if (player.pos - SHORTCUT_A).length() < SHORTCUT_R:
                player.near_shortcut_a = True
            if player.near_shortcut_a and (player.pos - SHORTCUT_B).length() < SHORTCUT_R:
                # "cut" forward by nudging position toward a later point on the centerline
                _, si, t = nearest_on_polyline_cached(player.pos)
                s = polyline_progress_cached(si, t)
                p2, _, _ = point_at_progress_cached(s + 140)
                player.pos = player.pos.lerp(p2, 0.65)
                player.near_shortcut_a = False

            # Checkpoints
            for i, cp_s in enumerate(CP_S):
                cp_p, _, _ = point_at_progress_cached(cp_s)
                if (player.pos - cp_p).length() < CP_RADIUS:
                    player.cp_mask |= (1 << i)

            # AI checkpoints
            for i, cp_s in enumerate(CP_S):
                cp_p, _, _ = point_at_progress_cached(cp_s)
                if (ai.pos - cp_p).length() < CP_RADIUS:
                    ai.cp_mask |= (1 << i)

            # Drift efficiency metric
            forward = v_from_angle(player.ang)
            _, side_v = drift_metrics(player.vel, forward)
            drifting = side_v.length() > 1.25 and player.vel.length() > 2.2
            drive_time += dt
            if drifting:
                drift_time += dt

            # Finish condition: cross start line after all checkpoints
            if (player.pos - START_POS).length() < 55 and player.cp_mask == 0b111 and player.vel.length() > 2.0:
                player.finished = True

            if (ai.pos - START_POS).length() < 55 and ai.cp_mask == 0b111 and ai.vel.length() > 2.0:
                ai.finished = True

            # End race when player finishes (vertical slice: one lap)
            if player.finished:
                ai_time = ai.time if ai.finished else ai.time + 1.2
                drift_eff = 0.0 if drive_time <= 1e-6 else (drift_time / drive_time) * 100.0
                outcome = "WIN" if player.time < ai_time else "LOSE"
                result = {
                    "player_time": player.time,
                    "ai_time": ai_time,
                    "outcome": outcome,
                    "drift_eff": drift_eff,
                }
                state = "RESULT"

        elif state == "RESULT":
            if keys[pygame.K_RETURN]:
                player, ai, state, countdown, result = reset_race()
                drift_time = 0.0
                drive_time = 0.0
                ai_target_s = 0.0

        # Reset hotkey anytime
        if keys[pygame.K_r]:
            player, ai, state, countdown, result = reset_race()
            drift_time = 0.0
            drive_time = 0.0
            ai_target_s = 0.0

        # Draw
        draw_track()
        draw_car(ai.pos, ai.ang, (170, 170, 190))
        draw_car(player.pos, player.ang, (255, 255, 255))

        # Minimal labels
        g = FONT.render("Ghostline", True, (170, 170, 190))
        screen.blit(g, (ai.pos.x - g.get_width() // 2, ai.pos.y - 28))

        draw_hud(player, ai, state, countdown, result)
        pygame.display.flip()

    pygame.quit()


def try_relaunch_with_pygame_env():
    """Relaunch with a known working Python env when pygame is unavailable."""
    script_path = Path(__file__).resolve()
    root = script_path.parent
    fallback_py = root / ".venv-pygame312" / "Scripts" / "python.exe"
    current_py = Path(sys.executable).resolve()

    if not fallback_py.exists():
        return False
    if fallback_py.resolve() == current_py:
        return False

    cmd = [str(fallback_py), str(script_path), *sys.argv[1:]]
    print("pygame not found in current interpreter. Relaunching with .venv-pygame312...")
    result = subprocess.run(cmd, check=False)
    sys.exit(result.returncode)


def main():
    parser = argparse.ArgumentParser(description="Slipstream City car game")
    parser.add_argument("--self-test", action="store_true", help="Run fast non-GUI validation tests and exit")
    args = parser.parse_args()

    if args.self_test:
        ok = run_self_test()
        print("SELF_TEST:PASS" if ok else "SELF_TEST:FAIL")
        return

    if not HAS_PYGAME and try_relaunch_with_pygame_env():
        return

    try:
        init_game_runtime()
        run_game_loop()
    except RuntimeError as ex:
        print(f"RuntimeError: {ex}")
        print("Install pygame in this interpreter, or run with .venv-pygame312\\Scripts\\python.exe")
        sys.exit(1)


if __name__ == "__main__":
    main()


