    # Draw "road" as thick polyline
    pygame.draw.lines(screen, ROAD, False, center, TRACK_W)
    # Narrow chicane overlay
    pygame.draw.lines(screen, ROAD, False, center, NARROW_W)

    # Neon edges (two passes)
    pygame.draw.lines(screen, NEON, False, center, TRACK_W + 10)
    pygame.draw.lines(screen, NEON2, False, center, TRACK_W + 4)

    # Oil slick
    pygame.draw.circle(screen, (15, 15, 15), OIL_POS, OIL_R)
    pygame.draw.circle(screen, (40, 40, 40), OIL_POS, OIL_R, 2)

    # Shortcut gate
    pygame.draw.circle(screen, YELLOW, SHORTCUT_A, SHORTCUT_R, 2)
    pygame.draw.circle(screen, YELLOW, SHORTCUT_B, SHORTCUT_R, 2)
