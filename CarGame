def clamp(x, a, b):
    return a if x < a else b if x > b else x

def v_from_angle(deg):
    r = math.radians(deg)
    return pygame.Vector2(math.cos(r), -math.sin(r))

def dist_point_to_segment(p, a, b):
    ap = p - a
    ab = b - a
    ab2 = ab.dot(ab)
    if ab2 <= 1e-9:
        return ap.length()
    t = clamp(ap.dot(ab) / ab2, 0.0, 1.0)
    proj = a + ab * t
    return (p - proj).length()

def nearest_on_polyline(p, pts):
    best_d = 1e9
    best_i = 0
    best_t = 0.0
    for i in range(len(pts) - 1):
        a, b = pts[i], pts[i + 1]
        ap = p - a
        ab = b - a
        ab2 = ab.dot(ab)
        t = 0.0 if ab2 <= 1e-9 else clamp(ap.dot(ab) / ab2, 0.0, 1.0)
        proj = a + ab * t
        d = (p - proj).length()
        if d < best_d:
            best_d, best_i, best_t = d, i, t
    return best_d, best_i, best_t

def polyline_progress(pts, seg_i, t):
    # returns distance along polyline
    d = 0.0
    for i in range(seg_i):
        d += (pts[i + 1] - pts[i]).length()
    d += (pts[seg_i + 1] - pts[seg_i]).length() * t
    return d

def polyline_total(pts):
    return sum((pts[i + 1] - pts[i]).length() for i in range(len(pts) - 1))

def point_at_progress(pts, s):
    # s in [0,total)
    total = polyline_total(pts)
    s = s % total
    for i in range(len(pts) - 1):
        seg = (pts[i + 1] - pts[i])
        L = seg.length()
        if s <= L:
            t = 0.0 if L <= 1e-9 else s / L
            return pts[i] + seg * t, i, t
        s -= L
    return pts[-1], len(pts) - 2, 1.0

