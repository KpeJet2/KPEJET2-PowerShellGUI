    class _MiniVector2:
        def __init__(self, x=0.0, y=0.0):
            self.x = float(x)
            self.y = float(y)

        def __add__(self, other):
            return _MiniVector2(self.x + other.x, self.y + other.y)

        def __sub__(self, other):
            return _MiniVector2(self.x - other.x, self.y - other.y)

        def __mul__(self, value):
            return _MiniVector2(self.x * value, self.y * value)

        def __rmul__(self, value):
            return self.__mul__(value)

        def __imul__(self, value):
            self.x *= value
            self.y *= value
            return self

        def copy(self):
            return _MiniVector2(self.x, self.y)

        def dot(self, other):
            return self.x * other.x + self.y * other.y

        def length(self):
            return math.hypot(self.x, self.y)

        def normalize(self):
            L = self.length()
            return _MiniVector2(0.0, 0.0) if L <= 1e-9 else _MiniVector2(self.x / L, self.y / L)

        def scale_to_length(self, value):
            L = self.length()
            if L > 1e-9:
                s = value / L
                self.x *= s
                self.y *= s

        def lerp(self, other, t):
            return _MiniVector2(self.x + (other.x - self.x) * t, self.y + (other.y - self.y) * t)

    class _MiniPygame:
        Vector2 = _MiniVector2
        K_UP = 273
        K_DOWN = 274
        K_LEFT = 276
        K_RIGHT = 275
        K_SPACE = 32
        K_ESCAPE = 27
        K_RETURN = 13
        K_r = 114

    pygame = _MiniPygame()

