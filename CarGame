def build_track_cache(pts):
    segments = []
    lengths = []
    lengths_sq = []
    cumulative = [0.0]
    total = 0.0
    for i in range(len(pts) - 1):
        seg = pts[i + 1] - pts[i]
        seg_len = seg.length()
        segments.append(seg)
        lengths.append(seg_len)
        lengths_sq.append(seg.dot(seg))
        total += seg_len
        cumulative.append(total)
    return {
        "segments": segments,
        "lengths": lengths,
        "lengths_sq": lengths_sq,
        "cumulative": cumulative,
        "total": total,
    }


TRACK_CACHE = build_track_cache(center)

TOTAL_S = TRACK_CACHE["total"]

# Start/finish line near first point
START_POS = pygame.Vector2(200, 520)
START_DIR = 0  # facing right

# Checkpoints (progress distances along centerline)
CP_S = [TOTAL_S * 0.25, TOTAL_S * 0.50, TOTAL_S * 0.75]
CP_RADIUS = 55

# Oil slick zone (a circle)
OIL_POS = pygame.Vector2(720, 360)
OIL_R = 55

# Shortcut gate (risk-reward): a narrow "portal" near top-right
SHORTCUT_A = pygame.Vector2(760, 310)
SHORTCUT_B = pygame.Vector2(860, 360)
SHORTCUT_R = 18

def track_width_at(p):
    # Narrow chicane region around mid-top
    # (simple: if near those points, narrow)
    chicane_center = pygame.Vector2(470, 285)
    if (p - chicane_center).length() < 170:
        return NARROW_W
    return TRACK_W

def on_track(p):
    d, _, _ = nearest_on_polyline_cached(p)
    return d <= track_width_at(p) * 0.5


def nearest_on_polyline_cached(p):
    best_d = 1e9
    best_i = 0
    best_t = 0.0
    segments = TRACK_CACHE["segments"]
    lengths_sq = TRACK_CACHE["lengths_sq"]
    for i in range(len(segments)):
        a = center[i]
        ab = segments[i]
        ap = p - a
        ab2 = lengths_sq[i]
        t = 0.0 if ab2 <= 1e-9 else clamp(ap.dot(ab) / ab2, 0.0, 1.0)
        proj = a + ab * t
        d = (p - proj).length()
        if d < best_d:
            best_d, best_i, best_t = d, i, t
    return best_d, best_i, best_t


def polyline_progress_cached(seg_i, t):
    return TRACK_CACHE["cumulative"][seg_i] + TRACK_CACHE["lengths"][seg_i] * t


def point_at_progress_cached(s):
    total = TRACK_CACHE["total"]
    s = s % total
    lengths = TRACK_CACHE["lengths"]
    segments = TRACK_CACHE["segments"]
    for i in range(len(lengths)):
        seg_len = lengths[i]
        if s <= seg_len:
            t = 0.0 if seg_len <= 1e-9 else s / seg_len
            return center[i] + segments[i] * t, i, t
        s -= seg_len
    return center[-1], len(center) - 2, 1.0

# -----------------------------
# Car physics (drift-capable)
# -----------------------------
@dataclass
class CarTuning:
    max_speed: float = 8.0
    accel: float = 0.28
    brake: float = 0.38
    turn_deg: float = 3.2
    friction: float = 0.985
    drift_factor: float = 0.90
    boost_force: float = 0.55

@dataclass
class CarState:
    pos: object
    vel: object
    ang: float
    boost: float = 0.0
    chain: float = 1.0
    chain_timer: float = 0.0
    crashed: bool = False
    finished: bool = False
    time: float = 0.0
    cp_mask: int = 0  # bitmask for checkpoints
    near_shortcut_a: bool = False

def drift_metrics(vel, forward):
    fwd_v = forward * vel.dot(forward)
    side_v = vel - fwd_v
    return fwd_v, side_v

def update_player(car: CarState, tune: CarTuning, dt, keys):
    forward = v_from_angle(car.ang)

    if keys[pygame.K_UP]:
        car.vel += forward * tune.accel
    if keys[pygame.K_DOWN]:
        car.vel -= forward * tune.brake

    speed = car.vel.length()
    if speed > 0.6:
        steer_scale = speed / tune.max_speed
        if keys[pygame.K_LEFT]:
            car.ang += tune.turn_deg * steer_scale
        if keys[pygame.K_RIGHT]:
            car.ang -= tune.turn_deg * steer_scale

    # Drift physics
    fwd_v, side_v = drift_metrics(car.vel, forward)

    # Oil reduces grip (more sideways retained)
    drift_factor = tune.drift_factor
    if (car.pos - OIL_POS).length() < OIL_R:
        drift_factor = min(0.97, drift_factor + 0.06)

    drifting = side_v.length() > 1.25 and speed > 2.2

    # Drift chain logic
    if drifting:
        car.chain_timer = 0.0
        car.chain = clamp(car.chain + 0.35 * dt, 1.0, 3.0)
        gain = (28.0 * car.chain) * dt
        car.boost = clamp(car.boost + gain, 0.0, 100.0)
    else:
        car.chain_timer += dt
        if car.chain_timer > 0.55:
            car.chain = 1.0

    car.vel = fwd_v + side_v * drift_factor
    car.vel *= tune.friction

    if car.vel.length() > tune.max_speed:
        car.vel.scale_to_length(tune.max_speed)

    # Boost (SPACE)
    if keys[pygame.K_SPACE] and car.boost > 0:
        car.vel += forward * tune.boost_force
        car.boost = clamp(car.boost - 55.0 * dt, 0.0, 100.0)

    car.pos += car.vel

def update_ai(car: CarState, tune: CarTuning, dt, target_s, aggression=0.55):
    # AI follows centerline with lookahead; uses same drift physics
    lookahead = 90 + car.vel.length() * 10
    target_point, _, _ = point_at_progress_cached(target_s + lookahead)

    to_t = (target_point - car.pos)
    if to_t.length() > 1e-6:
        desired = to_t.normalize()
    else:
        desired = v_from_angle(car.ang)

    desired_ang = math.degrees(math.atan2(-desired.y, desired.x))
    # shortest angle diff
    diff = (desired_ang - car.ang + 180) % 360 - 180

    speed = car.vel.length()
    if speed > 0.6:
        car.ang += clamp(diff, -tune.turn_deg, tune.turn_deg) * (speed / tune.max_speed)

    forward = v_from_angle(car.ang)

    # Throttle logic: slow for tight turns
    turn_severity = abs(diff) / 180.0
    want_speed = tune.max_speed * (1.0 - 0.55 * turn_severity)
    want_speed = clamp(want_speed, 3.0, tune.max_speed)

    if speed < want_speed:
        car.vel += forward * (tune.accel * (0.85 + aggression * 0.3))
    else:
        car.vel -= forward * (tune.brake * (0.35 + turn_severity * 0.6))

    # AI boost: uses it on straights if earned
    fwd_v, side_v = drift_metrics(car.vel, forward)
    drifting = side_v.length() > 1.15 and speed > 2.0
    if drifting:
        car.boost = clamp(car.boost + (18.0 * dt), 0.0, 100.0)

    # Spend boost when aligned and fast
    if car.boost > 20 and abs(diff) < 10 and speed > 4.5:
        car.vel += forward * (tune.boost_force * 0.75)
        car.boost = clamp(car.boost - 35.0 * dt, 0.0, 100.0)

    # Drift physics
    drift_factor = tune.drift_factor
    if (car.pos - OIL_POS).length() < OIL_R:
        drift_factor = min(0.97, drift_factor + 0.06)

    car.vel = fwd_v + side_v * drift_factor
    car.vel *= tune.friction

    if car.vel.length() > tune.max_speed:
        car.vel.scale_to_length(tune.max_speed)

    car.pos += car.vel

