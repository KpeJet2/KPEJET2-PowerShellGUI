function loadChangelog() {
  var sel = document.getElementById('logSelect').value;
  var content = (sel === 'CHANGELOG') ? CHANGELOG_CONTENT : ENHANCEMENTS_CONTENT;
  if (!content) {
    document.getElementById('browseContent').innerHTML = '<div class="empty-state"><div class="icon">⚠</div>Changelog not loaded. Place the file alongside this XHTML.</div>';
    return;
  }
  _rawLines = content.split('\n');
  _versions = parseChangelog(_rawLines);
  populateVersionDropdowns();
  applyFilters();
}

function parseChangelog(lines) {
  var versions = [];
  var cur = null;
  var curSection = '';
  for (var i = 0; i < lines.length; i++) {
    var ln = lines[i];
    // Version header: ## [tag] — date  OR  ## ⚙ date — Session ...
    var m = ln.match(/^## \[([^\]]+)\]\s*[—–-]\s*(\d{4}-\d{2}-\d{2})/);
    if (!m) { m = ln.match(/^## [⚙📌🔧✨🆕]\s*(\d{4}-\d{2}-\d{2})\s*[—–-]\s*(.*)/); }
    if (m) {
      if (cur) { versions.push(cur); }
      cur = { tag: m[1], date: m[2] || m[1], sections: {}, raw: ln + '\n', lineStart: i };
      curSection = '';
      continue;
    }
    if (!cur) continue;
    cur.raw += ln + '\n';
    // Section header: ### Added, ### Changed, etc.
    var sm = ln.match(/^### (Added|Changed|Fixed|Removed|Security|Deprecated|Pipeline Metrics)/);
    if (sm) { curSection = sm[1]; if (!cur.sections[curSection]) { cur.sections[curSection] = []; } continue; }
    // List items
    if (curSection && ln.match(/^- /)) {
      cur.sections[curSection].push(ln.substring(2));
    }
    // Table rows (pipeline metrics)
    if (curSection === 'Pipeline Metrics' && ln.match(/^\|/) && !ln.match(/^\|[\s-|]+$/)) {
      cur.sections[curSection].push(ln);
    }
  }
  if (cur) { versions.push(cur); }
  return versions;
}

function populateVersionDropdowns() {
  var opts = '';
  for (var i = 0; i < _versions.length; i++) {
    var v = _versions[i];
    opts += '<option value="' + i + '">' + escHtml(v.tag) + ' (' + v.date + ')</option>';
  }
  document.getElementById('diffFrom').innerHTML = opts;
  document.getElementById('diffTo').innerHTML = opts;
  document.getElementById('combFrom').innerHTML = opts;
  document.getElementById('combTo').innerHTML = opts;
  if (_versions.length > 1) {
    document.getElementById('diffFrom').selectedIndex = 1;
    document.getElementById('diffTo').selectedIndex = 0;
    document.getElementById('combFrom').selectedIndex = _versions.length - 1;
    document.getElementById('combTo').selectedIndex = 0;
  }
}

// ═══════════════════════════════════════════════════════════
// FILTERING
// ═══════════════════════════════════════════════════════════
function applyFilters() {
  var search   = (document.getElementById('searchInput').value || '').toLowerCase();
  var dateFrom = document.getElementById('dateFrom').value;
  var dateTo   = document.getElementById('dateTo').value;
  var category = document.getElementById('categoryFilter').value;
  var typeVal  = document.getElementById('typeFilter').value;

  var typeMap = { sin: '\u2E38', feature: '\u2699', file: '\uD83D\uDCC4', manifest: '\uD83D\uDCCB', pipeline: '\uD83D\uDD01', tracking: '\uD83D\uDCCC' };

  var filtered = [];
  var totals = { Added: 0, Changed: 0, Fixed: 0, Files: 0, Sins: 0 };

  for (var i = 0; i < _versions.length; i++) {
    var v = _versions[i];
    // Date filter
    if (dateFrom && v.date < dateFrom) continue;
    if (dateTo && v.date > dateTo) continue;

    var vFiltered = { tag: v.tag, date: v.date, sections: {}, raw: v.raw };
    var hasMatch = false;

    for (var sec in v.sections) {
      if (!v.sections.hasOwnProperty(sec)) continue;
      if (category && sec !== category) continue;
      var items = v.sections[sec];
      var filteredItems = [];
      for (var j = 0; j < items.length; j++) {
        var item = items[j];
        if (search && item.toLowerCase().indexOf(search) === -1) continue;
        if (typeVal && item.indexOf(typeMap[typeVal] || '___') === -1) continue;
        filteredItems.push(item);
        // Count totals
        if (sec === 'Added') totals.Added++;
        if (sec === 'Changed') totals.Changed++;
        if (sec === 'Fixed') totals.Fixed++;
        if (item.indexOf('\uD83D\uDCC4') !== -1) totals.Files++;
        if (item.indexOf('\u2E38') !== -1) totals.Sins++;
      }
      if (filteredItems.length > 0) {
        vFiltered.sections[sec] = filteredItems;
        hasMatch = true;
      }
    }
    // If no category/type/search filter, show version even if empty sections
    if (!category && !typeVal && !search) hasMatch = true;
    if (hasMatch) filtered.push(vFiltered);
  }

  // Update stats
  document.getElementById('statVersions').textContent = filtered.length;
  document.getElementById('statAdded').textContent    = totals.Added;
  document.getElementById('statChanged').textContent  = totals.Changed;
  document.getElementById('statFixed').textContent    = totals.Fixed;
  document.getElementById('statFiles').textContent    = totals.Files;
  document.getElementById('statSins').textContent     = totals.Sins;

  renderVersions(filtered, search);
}

function clearFilters() {
  document.getElementById('searchInput').value = '';
  document.getElementById('dateFrom').value = '';
  document.getElementById('dateTo').value = '';
  document.getElementById('categoryFilter').selectedIndex = 0;
  document.getElementById('typeFilter').selectedIndex = 0;
  applyFilters();
}

// ═══════════════════════════════════════════════════════════
// RENDERING
// ═══════════════════════════════════════════════════════════
function renderVersions(versions, highlight) {
  var html = '';
  if (versions.length === 0) {
    html = '<div class="empty-state"><div class="icon">🔍</div>No entries match the current filters</div>';
  }
  for (var i = 0; i < versions.length; i++) {
    var v = versions[i];
    html += '<div class="version-block">';
    html += '<h2>' + escHtml(v.tag) + ' <span class="date">' + v.date + '</span></h2>';
    for (var sec in v.sections) {
      if (!v.sections.hasOwnProperty(sec)) continue;
      var tagClass = 'tag-' + sec.toLowerCase().replace(/\s.*/,'');
      html += '<h3><span class="tag ' + tagClass + '">' + escHtml(sec) + '</span></h3>';
      if (sec === 'Pipeline Metrics') {
        html += renderTable(v.sections[sec]);
      } else {
        html += '<ul>';
        for (var j = 0; j < v.sections[sec].length; j++) {
          var txt = escHtml(v.sections[sec][j]);
          if (highlight) { txt = highlightText(txt, highlight); }
          html += '<li>' + txt + '</li>';
        }
        html += '</ul>';
      }
    }
    html += '</div>';
  }
  document.getElementById('browseContent').innerHTML = html;
}

function renderTable(rows) {
  if (rows.length < 2) return '';
  var html = '<table>';
  for (var i = 0; i < rows.length; i++) {
    var cells = rows[i].split('|').filter(function(c) { return c.trim() !== ''; });
    if (i === 0) {
      html += '<thead><tr>';
      for (var c = 0; c < cells.length; c++) html += '<th>' + escHtml(cells[c].trim()) + '</th>';
      html += '</tr></thead><tbody>';
    } else if (!rows[i].match(/^[\s|:-]+$/)) {
      html += '<tr>';
      for (var c = 0; c < cells.length; c++) html += '<td>' + escHtml(cells[c].trim()) + '</td>';
      html += '</tr>';
    }
  }
  html += '</tbody></table>';
  return html;
}

function highlightText(text, term) {
  if (!term) return text;
  var idx = text.toLowerCase().indexOf(term.toLowerCase());
  if (idx === -1) return text;
  return text.substring(0, idx) + '<span class="highlight">' + text.substring(idx, idx + term.length) + '</span>' + text.substring(idx + term.length);
}

function escHtml(s) {
  var d = document.createElement('div');
  d.appendChild(document.createTextNode(s));
  return d.innerHTML;
}

// ═══════════════════════════════════════════════════════════
// DIFFERENTIAL COMPARISON
// ═══════════════════════════════════════════════════════════
function computeDiff() {
  var fi = parseInt(document.getElementById('diffFrom').value, 10);
  var ti = parseInt(document.getElementById('diffTo').value, 10);
  if (isNaN(fi) || isNaN(ti) || fi === ti) { alert('Select two different versions'); return; }

  var vFrom = _versions[fi];
  var vTo   = _versions[ti];

  document.getElementById('diffLeftHeader').textContent  = vFrom.tag + ' (' + vFrom.date + ')';
  document.getElementById('diffRightHeader').textContent = vTo.tag + ' (' + vTo.date + ')';

  // Build sets for comparison
  var leftItems  = collectAllItems(vFrom);
  var rightItems = collectAllItems(vTo);

  var leftHtml = '', rightHtml = '';

  // Items only in left (removed relative to right)
  for (var i = 0; i < leftItems.length; i++) {
    if (rightItems.indexOf(leftItems[i]) === -1) {
      leftHtml += '<span class="diff-del">- ' + escHtml(leftItems[i]) + '</span>';
    } else {
      leftHtml += '<span class="diff-ctx">  ' + escHtml(leftItems[i]) + '</span>';
    }
  }

  // Items only in right (added relative to left)
  for (var i = 0; i < rightItems.length; i++) {
    if (leftItems.indexOf(rightItems[i]) === -1) {
      rightHtml += '<span class="diff-add">+ ' + escHtml(rightItems[i]) + '</span>';
    } else {
      rightHtml += '<span class="diff-ctx">  ' + escHtml(rightItems[i]) + '</span>';
    }
  }

  document.getElementById('diffLeft').innerHTML  = leftHtml || '<span class="diff-ctx">(no entries)</span>';
  document.getElementById('diffRight').innerHTML = rightHtml || '<span class="diff-ctx">(no entries)</span>';
}

function collectAllItems(version) {
  var items = [];
  for (var sec in version.sections) {
    if (!version.sections.hasOwnProperty(sec)) continue;
    for (var i = 0; i < version.sections[sec].length; i++) {
      items.push('[' + sec + '] ' + version.sections[sec][i]);
    }
  }
  return items;
}

// ═══════════════════════════════════════════════════════════
// COMBINED VIEW
// ═══════════════════════════════════════════════════════════
function buildCombined() {
  var fi = parseInt(document.getElementById('combFrom').value, 10);
  var ti = parseInt(document.getElementById('combTo').value, 10);
  if (isNaN(fi) || isNaN(ti)) { alert('Select version range'); return; }
  var lo = Math.min(fi, ti);
  var hi = Math.max(fi, ti);

  var merged = { Added: [], Changed: [], Fixed: [], Removed: [], Security: [], Deprecated: [], 'Pipeline Metrics': [] };
  for (var i = lo; i <= hi; i++) {
    var v = _versions[i];
    for (var sec in v.sections) {
      if (!v.sections.hasOwnProperty(sec)) continue;
      if (!merged[sec]) merged[sec] = [];
      for (var j = 0; j < v.sections[sec].length; j++) {
        merged[sec].push(v.sections[sec][j] + '  [' + v.tag + ']');
      }
    }
  }

  var fromTag = _versions[hi].tag;
  var toTag   = _versions[lo].tag;
  var fname   = 'combined-' + fromTag.replace(/\./g,'-') + '_to_' + toTag.replace(/\./g,'-') + '.mdv';

  document.getElementById('combBanner').style.display = 'flex';
  document.getElementById('combFilename').textContent = fname;

  var html = '<div class="version-block">';
  html += '<h2>Combined: ' + escHtml(fromTag) + ' → ' + escHtml(toTag) + '</h2>';
  for (var sec in merged) {
    if (!merged.hasOwnProperty(sec) || merged[sec].length === 0) continue;
    var tagClass = 'tag-' + sec.toLowerCase().replace(/\s.*/,'');
    html += '<h3><span class="tag ' + tagClass + '">' + escHtml(sec) + '</span> (' + merged[sec].length + ')</h3>';
    html += '<ul>';
    for (var k = 0; k < merged[sec].length; k++) {
      html += '<li>' + escHtml(merged[sec][k]) + '</li>';
    }
    html += '</ul>';
  }
  html += '</div>';
  document.getElementById('combContent').innerHTML = html;
}

// ═══════════════════════════════════════════════════════════
// .MDV EXPORT / MANAGEMENT
// ═══════════════════════════════════════════════════════════
function exportMdv() {
  var fi = parseInt(document.getElementById('diffFrom').value, 10);
  var ti = parseInt(document.getElementById('diffTo').value, 10);
  if (isNaN(fi) || isNaN(ti) || fi === ti) { alert('Run a comparison first'); return; }

  var vFrom = _versions[fi];
  var vTo   = _versions[ti];
  var fname = 'diff-' + vFrom.tag.replace(/\./g,'-') + '_vs_' + vTo.tag.replace(/\./g,'-') + '.mdv';

  var md = '<!-- Virtual Differential Markdown -->\n';
  md += '<!-- Generated: ' + new Date().toISOString() + ' -->\n';
  md += '<!-- Source: CHANGELOG.md -->\n\n';
  md += '# Differential: ' + vFrom.tag + ' vs ' + vTo.tag + '\n\n';

  md += '## Removed in ' + vTo.tag + ' (present in ' + vFrom.tag + ')\n\n';
  var leftItems  = collectAllItems(vFrom);
  var rightItems = collectAllItems(vTo);
  for (var i = 0; i < leftItems.length; i++) {
    if (rightItems.indexOf(leftItems[i]) === -1) { md += '- ~~' + leftItems[i] + '~~\n'; }
  }

  md += '\n## Added in ' + vTo.tag + ' (not in ' + vFrom.tag + ')\n\n';
  for (var i = 0; i < rightItems.length; i++) {
    if (leftItems.indexOf(rightItems[i]) === -1) { md += '- **' + rightItems[i] + '**\n'; }
  }

  saveMdv(fname, md);
  alert('Exported: ' + fname);
}

function exportCombinedMdv() {
  var fi = parseInt(document.getElementById('combFrom').value, 10);
  var ti = parseInt(document.getElementById('combTo').value, 10);
  if (isNaN(fi) || isNaN(ti)) { alert('Build a combined view first'); return; }
  var lo = Math.min(fi, ti);
  var hi = Math.max(fi, ti);

  var fromTag = _versions[hi].tag;
  var toTag   = _versions[lo].tag;
  var fname = 'combined-' + fromTag.replace(/\./g,'-') + '_to_' + toTag.replace(/\./g,'-') + '.mdv';

  var md = '<!-- Virtual Combined Markdown -->\n';
  md += '<!-- Generated: ' + new Date().toISOString() + ' -->\n';
  md += '<!-- Source: CHANGELOG.md -->\n';
  md += '<!-- Range: ' + fromTag + ' to ' + toTag + ' -->\n\n';
  md += '# Combined Changelog: ' + fromTag + ' → ' + toTag + '\n\n';

  for (var i = lo; i <= hi; i++) {
    md += _versions[i].raw + '\n';
  }

  saveMdv(fname, md);
  alert('Exported: ' + fname);
}

function saveMdv(filename, content) {
  // Check for existing
  for (var i = 0; i < _mdvStore.length; i++) {
    if (_mdvStore[i].filename === filename) {
      _mdvStore[i].content = content;
      _mdvStore[i].created = new Date().toISOString();
      persistMdvStore();
      return;
    }
  }
  _mdvStore.push({ filename: filename, content: content, created: new Date().toISOString() });
  persistMdvStore();
}

function persistMdvStore() {
  try { localStorage.setItem('pwshgui_mdv_store', JSON.stringify(_mdvStore)); } catch(e) { /* quota */ }
}

function loadMdvStore() {
  try {
    var s = localStorage.getItem('pwshgui_mdv_store');
    if (s) { _mdvStore = JSON.parse(s); }
  } catch(e) { _mdvStore = []; }
}

function refreshMdvList() {
  loadMdvStore();
  var sel = document.getElementById('mdvSelect');
  sel.innerHTML = '<option value="">— Select (' + _mdvStore.length + ' files) —</option>';
  for (var i = 0; i < _mdvStore.length; i++) {
    sel.innerHTML += '<option value="' + i + '">' + escHtml(_mdvStore[i].filename) + ' (' + _mdvStore[i].created.substring(0,10) + ')</option>';
  }
}

function loadMdv() {
  var idx = parseInt(document.getElementById('mdvSelect').value, 10);
  if (isNaN(idx) || !_mdvStore[idx]) {
    document.getElementById('mdvContent').innerHTML = '<div class="empty-state"><div class="icon">📄</div>Select an .mdv file</div>';
    return;
  }
  var mdv = _mdvStore[idx];
  var lines = mdv.content.split('\n');
  var html = '<div class="mdv-banner"><code>' + escHtml(mdv.filename) + '</code> Generated: ' + mdv.created + '</div>';
  html += '<div class="version-block" style="font-family: Consolas, monospace; font-size: 12px; white-space: pre-wrap; line-height: 1.7;">';
  for (var i = 0; i < lines.length; i++) {
    var ln = escHtml(lines[i]);
    if (lines[i].indexOf('~~') !== -1)  { html += '<span class="diff-del">' + ln + '</span>'; }
    else if (lines[i].indexOf('**') !== -1 && lines[i].indexOf('- **') !== -1) { html += '<span class="diff-add">' + ln + '</span>'; }
    else if (lines[i].indexOf('#') === 0) { html += '<span style="color:#2dd4bf;font-weight:bold;">' + ln + '</span>\n'; }
    else { html += ln + '\n'; }
  }
  html += '</div>';
  document.getElementById('mdvContent').innerHTML = html;
}

function clearMdvFiles() {
  if (!confirm('Clear all generated .mdv files from local storage?')) return;
  _mdvStore = [];
  persistMdvStore();
  refreshMdvList();
  document.getElementById('mdvContent').innerHTML = '<div class="empty-state"><div class="icon">🗑</div>All .mdv files cleared</div>';
}

