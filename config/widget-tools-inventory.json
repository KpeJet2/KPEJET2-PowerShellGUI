  "launchModes": {
    "inline": {
      "description": "Dot-sourced and invoked directly in Main-GUI context",
      "example": ". $script; FunctionName -Params"
    },
    "menu-script-safely": {
      "description": "Launched via Invoke-MenuScriptSafely helper (single-instance tracking)",
      "example": "Invoke-MenuScriptSafely -MenuLabel 'Name' -RelativeCandidates @('path.ps1')"
    },
    "menu-script-safely-newprocess": {
      "description": "Launched in new process via Invoke-MenuScriptSafely with -UseNewProcess",
      "example": "Invoke-MenuScriptSafely -MenuLabel 'Name' -RelativeCandidates @('path.ps1') -UseNewProcess"
    },
    "standalone": {
      "description": "Not menu-integrated; launched independently or via direct script call",
      "example": "Manual invocation from scripts/ folder"
    }
  },
  "maintenance": {
    "onNewTool": [
      "1. Create Show-*.ps1 script in scripts/ folder",
      "2. Add menu entry to Main-GUI.ps1 $toolsMenu section",
      "3. Add entry to this inventory (config/widget-tools-inventory.json)",
      "4. Create README.md if tool has multiple components",
      "5. Create batch launcher if tool benefits from standalone launch",
      "6. Run Build-AgenticManifest.ps1 to rebuild agentic-manifest.json",
      "7. Add pipeline item if tool has ongoing development/features",
      "8. Update ENHANCEMENTS-LOG.md with tool addition"
    ],
    "onToolUpdate": [
      "1. Update version in tool script header (VersionTag)",
      "2. Update lastUpdated field in this inventory",
      "3. Update README.md if features changed",
      "4. Re-run Build-AgenticManifest.ps1",
      "5. Log update in ENHANCEMENTS-LOG.md"
    ],
    "consistencyChecks": [
      "All Show-*.ps1 scripts have corresponding inventory entry",
      "All menu entries match menuPath/menuLabel in inventory",
      "All tools with batchLauncher have corresponding .bat file in root",
      "All tools with readme have corresponding README.md file",
      "Version tags match between script and inventory",
      "Dependencies list matches actual module imports in script"
    ]
  },
