      "remediation": ""
    },
    {
      "id": 2,
      "type": "FolderExists",
      "label": "Modules folder exists",
      "param": "C:\\PowerShellGUI\\modules",
      "remediation": ""
    },
    {
      "id": 3,
      "type": "FolderWritable",
      "label": "Logs folder is writable",
      "param": "C:\\PowerShellGUI\\logs",
      "remediation": ""
    },
    {
      "id": 4,
      "type": "ServiceRunning",
      "label": "Windows Update service is running",
      "param": "wuauserv",
      "remediation": "Start-Service wuauserv"
    },
    {
      "id": 5,
      "type": "ServiceExists",
      "label": "WinRM service exists",
      "param": "WinRM",
      "remediation": ""
    },
    {
      "id": 6,
      "type": "AppInstalled",
      "label": "PowerShell 7 is installed",
      "param": "PowerShell",
      "remediation": "winget install Microsoft.PowerShell"
    },
    {
      "id": 7,
      "type": "TimezoneEquals",
      "label": "Timezone is UTC+8",
      "param": "+8",
      "remediation": ""
    },
    {
      "id": 8,
