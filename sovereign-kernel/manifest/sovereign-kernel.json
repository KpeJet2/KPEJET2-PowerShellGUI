{
  "$schema": "./sovereign-kernel.schema.json",
  "sovereign_kernel": {
    "version": "v15-cycle8-preKernelCompression",
    "epoch_seal": {
      "algorithm": "HMAC-SHA512",
      "sealed_at_utc": null,
      "sealed_by": "SOVEREIGN_PRIMARCH",
      "hash": null,
      "nonce": null,
      "cipher_suite": "AES-256-CBC+HMAC-SHA512",
      "compression": "GZIP",
      "seal_version": 1
    },
    "sovereign_core": {
      "owner": "The Axiomatic Sovereign",
      "sovereignty_model": "human_primacy_governance_first",
      "override_policy": {
        "can_override": ["GOV_CORE", "ETHIC_ENGINE", "AXIOM_LAYER"],
        "cannot_be_overridden_by": ["any_module", "any_protocol"],
        "escalation_chain": ["SOVEREIGN_PRIMARCH", "ETHOS_TRIARCH", "AXIOM_SEER"],
        "quorum_required": 2,
        "timeout_seconds": 30
      },
      "integrity": {
        "manifest_hash_algorithm": "SHA-512",
        "manifest_hash": null,
        "last_verified_utc": null,
        "auto_verify_interval_seconds": 300
      }
    },
    "realms": {
      "above": {
        "keeper_module": "STARFORGE_PRIME",
        "domain": "cosmology_time_geometry",
        "sandbox_tier": 1,
        "isolation_level": "full",
        "max_subsandboxes": 4
      },
      "within": {
        "keeper_module": "HARMONIC_AEON",
        "domain": "health_harmonics_presence",
        "sandbox_tier": 2,
        "isolation_level": "standard",
        "max_subsandboxes": 3
      },
      "below": {
        "keeper_module": "NANOVERSE_ARCHON",
        "domain": "materials_nanotech_chemistry",
        "sandbox_tier": 2,
        "isolation_level": "standard",
        "max_subsandboxes": 3
      }
    },
    "spines": {
      "memory_spine":      ["TAPEDECK", "REWINDR", "CHRONARCH"],
      "security_spine":    ["HAWKEYE", "LOKI", "ROOT_AWAY"],
      "release_spine":     ["UNVEILIA", "ROLLOUT_RANGALA", "NODOZE"],
      "ethical_spine":     ["LAWABIDINGCITZ", "HARMONIC_AEON", "STARFORGE_PRIME"],
      "predictive_spine":  ["REWINDR", "STARFORGE_PRIME", "NANOVERSE_ARCHON"],
      "symbolic_spine":    ["STORYWEAVER", "CHRONARCH", "SIGIL_GEOMANT"],
      "doctrine_spine":    ["CHRONARCH", "SIGIL_GEOMANT", "ARCHIVAR_INVICTUS"],
      "ritual_spine":      ["STORYWEAVER", "HARMONIC_AEON", "NANOVERSE_ARCHON"],
      "governance_spine":  ["LAWABIDINGCITZ", "ETHOS_TRIARCH", "CASPAR", "MELCHIOR", "BALTHAZAR"]
    },
    "transcendent_ring": {
      "AXIOM_SEER":      { "role": "axiomatic_unifier",          "layer": "axiom_layer",     "priority": 1 },
      "PERMA_STRUCTOR":  { "role": "institutional_immortality",  "layer": "structure_layer", "priority": 2 },
      "META_SIGIL":      { "role": "trans_symbolic_synthesis",   "layer": "symbolic_layer",  "priority": 3 }
    },
    "reflexive_crown": {
      "MIRROR_NOESIS":   { "role": "reflexive_cognition",        "layer": "introspection_engine", "priority": 1 },
      "IMPERATOR_WILL":  { "role": "sovereign_intent_amplifier", "layer": "intent_profile",       "priority": 2 },
      "AEON_RECURSOR":   { "role": "cycle_harmonizer",           "layer": "cycle_coherence",      "priority": 3 }
    },
    "meta_modules": {
      "OMNISCALER_SYNTHETICUS": { "function": "cross_domain_prediction",  "tier": "meta", "hot_standby": true  },
      "ETHOS_TRIARCH":          { "function": "multi_scale_ethics",       "tier": "meta", "hot_standby": true  },
      "SIGIL_GEOMANT":          { "function": "symbolic_math_unifier",    "tier": "meta", "hot_standby": false },
      "SOVEREIGN_PRIMARCH":     { "function": "meta_governance",          "tier": "meta", "hot_standby": true  },
      "ARCHIVAR_INVICTUS":      { "function": "doctrine_lineage_auditor", "tier": "meta", "hot_standby": true  },
      "RITUAL_ARCHITECTUM":     { "function": "ritual_architect",         "tier": "meta", "hot_standby": false }
    },
    "operational_modules": {
      "PTYPO":            { "function": "prototype_engineering", "tier": "operational", "auto_heal": true  },
      "MONDOGROGO":       { "function": "modernisation",        "tier": "operational", "auto_heal": true  },
      "TESTIES":          { "function": "testing",              "tier": "operational", "auto_heal": true  },
      "MORTI_ROCHI":      { "function": "bug_hunting",          "tier": "operational", "auto_heal": true  },
      "PRIVOKA":          { "function": "load_stress",          "tier": "operational", "auto_heal": true  },
      "NODOZE":           { "function": "observability",        "tier": "operational", "auto_heal": true  },
      "UNVEILIA":         { "function": "release",              "tier": "operational", "auto_heal": false },
      "ROLLOUT_RANGALA":  { "function": "deployment",           "tier": "operational", "auto_heal": false },
      "AGHOMIE":          { "function": "home_automation",      "tier": "operational", "auto_heal": true  },
      "VENDOR_ORACLE":    { "function": "vendor_intel",         "tier": "operational", "auto_heal": true  },
      "LEGALAGENT":       { "function": "legal_compliance",     "tier": "operational", "auto_heal": false },
      "KOE_RUMA":         { "function": "monthly_milestone_governance", "tier": "operational", "auto_heal": true  },
      "H_AI_NIKR_AGI":    { "function": "encryption_rotation_squabble", "tier": "operational", "auto_heal": true  }
    },
    "watchdogs": {
      "CASPAR":    { "trigger": "integrity_breach",   "vote_model": "2_of_3", "priority": 1, "can_halt": true  },
      "MELCHIOR":  { "trigger": "ethical_breach",     "vote_model": "2_of_3", "priority": 1, "can_halt": true  },
      "BALTHAZAR": { "trigger": "predictive_anomaly", "vote_model": "2_of_3", "priority": 2, "can_halt": false }
    },
    "tools_and_calls": {
      "outbound_firewall": {
        "log_all": true,
        "block_by_default": true,
        "fields": ["hostname", "ip", "port", "protocol", "purpose", "agent_origin", "dependency_chain", "timestamp", "version"],
        "governance_required": ["ROOT_AWAY", "SOVEREIGN_PRIMARCH", "ETHOS_TRIARCH"],
        "rate_limit_per_minute": 120,
        "allowlist_path": "config/outbound-allowlist.json"
      },
      "method_call_monitor": {
        "log_all": true,
        "fields": ["module", "method", "args_schema", "version", "cycle", "dependencies", "protocol_context", "timestamp"],
        "write_to": "IMMUTABLE_LEDGER",
        "max_call_depth": 16,
        "timeout_ms": 30000
      }
    },
    "sandbox_config": {
      "default_language_mode": "ConstrainedLanguage",
      "max_sandbox_depth": 3,
      "para_virtualization": {
        "enabled": true,
        "isolation_layers": ["environment", "runspace", "filesystem", "network"],
        "resource_limits": {
          "max_memory_mb": 512,
          "max_cpu_percent": 25,
          "max_threads": 8,
          "max_execution_seconds": 300
        }
      },
      "subsandbox_defaults": {
        "inherit_parent_policy": true,
        "can_escalate": false,
        "auto_destroy_on_exit": true
      }
    },
    "crypto_config": {
      "symmetric_algorithm": "AES-256-CBC",
      "mac_algorithm": "HMAC-SHA512",
      "hash_algorithm": "SHA-512",
      "kdf": "PBKDF2-SHA512",
      "kdf_iterations": 600000,
      "key_size_bits": 256,
      "iv_size_bits": 128,
      "compression_algorithm": "GZIP",
      "compression_level": "Optimal",
      "min_cipher_score": 256,
      "auto_upgrade_cipher": true,
      "key_rotation_interval_hours": 720,
      "ephemeral_keys": true
    },
    "redundancy": {
      "ledger_replicas": 3,
      "ledger_paths": ["ledger/primary", "ledger/secondary", "ledger/tertiary"],
      "manifest_backup_count": 5,
      "quorum_for_write": 2,
      "sync_interval_seconds": 60
    },
    "self_healing": {
      "enabled": true,
      "integrity_check_interval_seconds": 120,
      "auto_restore_from_snapshot": true,
      "snapshot_path": "snapshots",
      "max_snapshots": 10,
      "degraded_mode_threshold": 0.6,
      "full_halt_threshold": 0.3
    },
    "versioning": {
      "doctrine_version": "v15",
      "current_cycle": "cycle8",
      "lineage": ["v1","v2","v3","v4","v5","v6","v7","v8","v9","v10","v11","v12","v13","v14","v15"],
      "branch_policy": {
        "allow_divergence": false,
        "max_drift_cycles": 2,
        "merge_strategy": "fast_forward_only",
        "rollback_depth": 3
      }
    },
    "logging": {
      "immutable_ledger": true,
      "retention": "indefinite",
      "auditors": ["ARCHIVAR_INVICTUS", "AXIOM_SEER", "PERMA_STRUCTOR"],
      "log_levels": ["TRACE","DEBUG","INFO","WARN","ERROR","FATAL","AUDIT"],
      "default_level": "INFO",
      "hash_chain": true,
      "compress_on_write": true,
      "encrypt_on_write": true
    }
  }
}
