# VersionTag: 2605.B5.V46.0
# VersionTag: 2605.B5.V46.0
# VersionTag: 2605.B5.V46.0
# VersionTag: 2605.B5.V46.0
# FocalPoint-null Environment Configuration
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to source control

# ─────────────────────────────────────────────
# MODEL CONFIGURATION
# ─────────────────────────────────────────────

# Option A: GitHub Models (default for development)
# Get your PAT at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat_here
GITHUB_MODEL_ENDPOINT=https://models.inference.ai.azure.com
ORCHESTRATOR_MODEL=gpt-4.1
SUBAGENT_MODEL=gpt-4.1-mini
SECURITY_MODEL=gpt-4.1-mini
REVIEW_MODEL=gpt-4.1

# Option B: Microsoft Foundry (recommended for production)
# Comment out GitHub options above and use these instead
# FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-id>
# FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1
# FOUNDRY_SUBAGENT_MODEL=gpt-4.1-mini

# ─────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────
HTTP_HOST=0.0.0.0
HTTP_PORT=8087
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8888
DASHBOARD_AUTO_OPEN=true
DEBUG_PORT=5679

# ─────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────
# Master secret for PKI bootstrap (change in production, use HSM in enterprise)
PKI_MASTER_SECRET=change_me_in_production_use_strong_secret_32chars_min

# ─────────────────────────────────────────────
# STORAGE PATHS (relative to project root)
# ─────────────────────────────────────────────
CHECKPOINT_DIR=checkpoints
LOG_DIR=logs
FORK_DIR=forks
PKI_DIR=pki
TODO_DIR=todo

# ─────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────
# Allow FocalPoint-null-00 to organically suggest new agents / improvements
ALLOW_AUTONOMOUS_ORGANIC_GROWTH=false
# Allow agents to access archived checkpoints (requires ALLOW-AGENT-ARCHIVAL-ACCESS tag + valid PKI)
ALLOW_AGENT_ARCHIVAL_ACCESS=false
# Maximum fork depth before blocking (prevents exponential growth post-testing)
MAX_FORK_DEPTH=3
MAX_FORK_PATHS=10
# Task retry limit before escalating to human review
TASK_MAX_RETRIES=3

# ─────────────────────────────────────────────
# MULTI-MODEL PARALLEL DISPATCH
# ─────────────────────────────────────────────
# Set true to dispatch every FocalPoint prompt to all configured AI endpoints simultaneously.
# ConsensusEngine cross-validates results and selects the highest-confidence winner.
# Additional endpoints are declared in config/focalpoint_config.yaml multi_model.additional_endpoints.
MULTI_MODEL_ENABLED=false
# Minimum confidence (0.0-1.0) before failover to secondary model is triggered
MULTI_MODEL_FAILOVER_THRESHOLD=0.35
# Per-endpoint HTTP timeout in seconds
MULTI_MODEL_TIMEOUT_SECONDS=30

# Additional model API keys — referenced by api_key_env in focalpoint_config.yaml.
# The NAME here is what you put in api_key_env in the config.
# Uncomment and fill in when activating additional endpoints.
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
# GEMINI_API_KEY=your_gemini_key_here
# MISTRAL_API_KEY=your_mistral_key_here
# OLLAMA_API_KEY=ollama







